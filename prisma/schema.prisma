// MoovStock — Sprint 1 → 4 schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  RESELLER
}

enum ItemStatus {
  IN_STOCK
  LISTED
  SOLD
  RETURNED
  LOST
}

enum PaymentStatus {
  PENDING
  PAID_TO_RESELLER
  SETTLED
}

enum AlertType {
  INACTIVITY        // n'a pas saisi DailyLog depuis X jours
  GOAL_MISSED       // objectif quotidien non atteint
  LOW_STOCK         // consommable bas (Sprint 3)
  RESTOCK_NOW       // rachat urgent (Sprint 3)
  STOCK_MISMATCH    // ventes vs pochettes utilisées incohérent
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum SupplyType {
  POUCH         // pochette d'envoi
  LABEL_ROLL    // rouleau d'étiquettes (compté en étiquettes restantes)
  PRINTER_INK   // encre / toner
  OTHER
}

enum MovementReason {
  RESTOCK         // rachat (delta positif)
  CONSUMPTION     // utilisation depuis DailyLog (delta négatif)
  MANUAL_ADJUST   // ajustement manuel (positif ou négatif)
  LOSS            // perte
}

enum TransactionType {
  INCOME           // recette diverse
  EXPENSE          // dépense
  RESELLER_PAYOUT  // reversement à un revendeur (sortie cash)
  REFUND           // remboursement émis (sortie cash)
}

enum TransactionCategory {
  STOCK_BUY        // achat de stock à revendre
  SUPPLIES         // pochettes / étiquettes / encre
  SHIPPING         // frais d'envoi non remboursés
  AD               // publicité
  PAYOUT           // commission revendeur
  REFUND           // remboursement acheteur
  EQUIPMENT        // imprimante, balance, etc.
  TRANSPORT        // déplacements
  OTHER
}

enum Account {
  CASH
  BANK
  PAYPAL
  REVOLUT
  OTHER
}

model User {
  id              String   @id @default(cuid())
  clerkId         String?  @unique // null = invité, pas encore inscrit
  email           String   @unique
  name            String?
  imageUrl        String?
  role            Role     @default(RESELLER)
  dailyGoalItems  Int      @default(5)
  commissionRate  Float    @default(0.5) // 0..1, part reversée au revendeur
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           Item[]
  sales           Sale[]   @relation("ResellerSales")
  dailyLogs       DailyLog[]
  alerts          Alert[]
  supplies        Supply[]
  transactions    Transaction[]

  @@index([role])
}

model Transaction {
  id            String              @id @default(cuid())

  type          TransactionType
  category      TransactionCategory @default(OTHER)
  account       Account             @default(CASH)

  amount        Float               // toujours positif ; le type indique l'impact cash
  date          DateTime            @default(now())
  note          String?

  // Optionnels — pour relier à un revendeur / une vente
  relatedUserId String?
  relatedUser   User?               @relation(fields: [relatedUserId], references: [id], onDelete: SetNull)

  relatedSaleId String?             @unique
  relatedSale   Sale?               @relation(fields: [relatedSaleId], references: [id], onDelete: SetNull)

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([date])
  @@index([account])
  @@index([type, category])
  @@index([relatedUserId])
}

model Supply {
  id                  String     @id @default(cuid())
  userId              String
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  type                SupplyType
  name                String?    // libellé custom : "Pochettes 25x35", "Étiquettes 60x40"

  quantity            Int        @default(0)   // stock courant
  unitCost            Float      @default(0)   // pour valoriser

  restockThreshold    Int?       // override manuel (en unités) ; sinon calculé
  restockLeadDays     Int        @default(3)   // délai de livraison fournisseur
  safetyMarginDays    Int        @default(2)   // marge de sécurité

  lastRestockedAt     DateTime?
  active              Boolean    @default(true)

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  movements           SupplyMovement[]

  @@index([userId, type, active])
}

model SupplyMovement {
  id          String         @id @default(cuid())
  supplyId    String
  supply      Supply         @relation(fields: [supplyId], references: [id], onDelete: Cascade)

  delta       Int            // + rachat / − consommation
  reason      MovementReason
  note        String?

  // Trace facultative vers la saisie qui a déclenché la consommation
  dailyLogId  String?

  createdAt   DateTime       @default(now())

  @@index([supplyId, createdAt])
  @@index([dailyLogId])
}

model DailyLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date            DateTime @db.Date  // date du jour (sans heure)

  itemsListed     Int      @default(0)
  itemsSold       Int      @default(0)
  pouchesUsed     Int      @default(0)
  labelsUsed      Int      @default(0)

  issues          String?  // problèmes : imprimante, colis annulé, etc.

  submittedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model Alert {
  id          String         @id @default(cuid())
  userId      String?        // null = alerte globale (admin only)
  user        User?          @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        AlertType
  severity    AlertSeverity  @default(WARNING)
  message     String

  // métadonnées libres pour contextualiser (ex: { goal: 10, achieved: 4 })
  meta        Json?

  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  @@index([userId, resolvedAt])
  @@index([type, resolvedAt])
}

model Item {
  id             String     @id @default(cuid())
  userId         String     // revendeur propriétaire
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String
  category       String?
  brand          String?
  size           String?
  condition      String?    // "Neuf avec étiquette", "Très bon état", etc.

  purchasePrice  Float      @default(0)
  listingPrice   Float      @default(0)

  photoUrl       String?
  vintedUrl      String?

  status         ItemStatus @default(IN_STOCK)
  listedAt       DateTime?
  soldAt         DateTime?

  notes          String?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  sale           Sale?

  @@index([userId, status])
  @@index([status])
}

model Sale {
  id              String        @id @default(cuid())

  itemId          String        @unique
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)

  resellerId      String
  reseller        User          @relation("ResellerSales", fields: [resellerId], references: [id], onDelete: Restrict)

  soldPrice       Float
  shippingFee     Float         @default(0) // payé par acheteur, pour info
  vintedFee       Float         @default(0) // commission Vinted côté vendeur si applicable
  pouchCost       Float         @default(0)
  labelCost       Float         @default(0)
  otherCost       Float         @default(0)

  // Snapshot des calculs au moment de la vente
  grossProfit     Float         @default(0) // soldPrice - purchasePrice - fees - consumables
  resellerPayout  Float         @default(0) // ce qu'on doit au revendeur
  netProfit       Float         @default(0) // grossProfit - resellerPayout (part admin)

  buyerCountry    String?
  soldAt          DateTime      @default(now())

  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?

  notes           String?

  payoutTransaction Transaction?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([resellerId, soldAt])
  @@index([paymentStatus])
}
