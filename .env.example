# --- Database (Neon) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Clerk Auth ---
# https://dashboard.clerk.com → ton application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# https://dashboard.clerk.com → Webhooks → après création de l'endpoint
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/post-login
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/post-login

# --- Cron (Vercel) ---
CRON_SECRET=replace-with-random-ascii-string
