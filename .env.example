# --- Database (Neon) ---
# Get from https://console.neon.tech → your project → Connection string (Pooled)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
# Unpooled connection for migrations (Neon → "Direct connection")
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Clerk Auth ---
# Get from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Get from Clerk dashboard → Webhooks → after creating the endpoint
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Business defaults (EUR) ---
DEFAULT_POUCH_COST=0.15
DEFAULT_LABEL_COST=0.05
DEFAULT_VINTED_FEE_RATE=0
